        "bottom": "auto",
        "left": "0",
        "z-index": "5"
      }
    },
    ".hero_featured-wrap": {
      "main": {
        "flex-shrink": "0",
        "width": "calc(var(--space-192) * 2.5)",
        "z-index": "10",
        "position": "relative"
      },
      "medium": {
        "width": "100%",
        "max-width": "calc(var(--space-192) * 2 + var(--space-64))"
      },
      "tiny": {
        "max-width": "100%"
      }
    },
    ".featured_card": {
      "main": {
        "background-color": "var(--color--black-55)",
        "backdrop-filter": "blur(var(--space-28))",
        "border-top-style": "solid",
        "border-top-color": "var(--color--white-8)",
        "border-right-style": "solid",
        "border-right-color": "var(--color--white-8)",
        "border-bottom-style": "solid",
        "border-bottom-color": "var(--color--white-8)",
        "border-left-style": "solid",
        "border-left-color": "var(--color--white-8)",
        "border-top-left-radius": "var(--space-28)",
        "border-top-right-radius": "var(--space-28)",
        "border-bottom-right-radius": "var(--space-28)",
        "border-bottom-left-radius": "var(--space-28)",
        "padding-top": "var(--space-16)",
        "padding-right": "var(--space-16)",
        "padding-bottom": "var(--space-16)",
        "padding-left": "var(--space-16)",
        "overflow": "hidden",
        "transition": "border-color 0.35s ease, background 0.35s ease"
      },
      "tiny": {
        "padding-top": "var(--space-16)",
        "padding-right": "var(--space-16)",
        "padding-bottom": "var(--space-16)",
        "padding-left": "var(--space-16)"
      }
    },
    ".featured_card:hover": {
      "main": {
        "border-top-color": "var(--color--white-16)",
        "border-right-color": "var(--color--white-16)",
        "border-bottom-color": "var(--color--white-16)",
        "border-left-color": "var(--color--white-16)",
        "background-color": "var(--color--black-65)"
      }
    },
    ".featured_card-image-wrap": {
      "main": {
        "position": "relative",
        "width": "100%",
        "aspect-ratio": "16 / 9",
        "border-top-left-radius": "var(--space-18)",
        "border-top-right-radius": "var(--space-18)",
        "border-bottom-right-radius": "var(--space-18)",
        "border-bottom-left-radius": "var(--space-18)",
        "overflow": "hidden",
        "margin-bottom": "var(--space-20)"
      }
    },
    ".featured_card-img": {
      "main": {
        "width": "100%",
        "height": "100%",
        "object-fit": "cover"
      }
    },
    ".featured_card-badge": {
      "main": {
        "position": "absolute",
        "top": "var(--space-14)",
        "left": "var(--space-14)",
        "width": "calc(var(--space-32) + var(--space-2))",
        "height": "calc(var(--space-32) + var(--space-2))",
        "background-color": "var(--color--white-18)",
        "backdrop-filter": "blur(var(--space-8))",
        "border-top-left-radius": "50%",
        "border-top-right-radius": "50%",
        "border-bottom-right-radius": "50%",
        "border-bottom-left-radius": "50%",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "z-index": "2"
      }
    },
    ".featured_card-content": {
      "main": {
        "padding-top": "0",
        "padding-right": "var(--space-4)",
        "padding-bottom": "0",
        "padding-left": "var(--space-4)"
      }
    },
    ".featured_card-name": {
      "main": {
        "font-family": "var(--font--heading)",
        "font-size": "var(--text--subtext-size)",
        "color": "var(--color--white)",
        "margin-bottom": "var(--space-8)"
      },
      "medium": {
        "font-size": "var(--text--body-size)"
      }
    },
    ".featured_card-desc": {
      "main": {
        "font-size": "var(--text--link)",
        "line-height": "var(--text--paragraph-lh)",
        "color": "var(--color--light-paragraph)",
        "margin-bottom": "var(--space-24)"
      }
    },
    ".featured_card-footer": {
      "main": {
        "display": "flex",
        "justify-content": "space-between",
        "align-items": "center",
        "padding-top": "var(--space-18)",
        "border-top-style": "solid",
        "border-top-color": "var(--color--white-8)"
      }
    },
    ".featured_card-tag": {
      "main": {
        "font-size": "var(--text--small)",
        "font-weight": "var(--weight--semibold)",
        "letter-spacing": "0.1em",
        "color": "var(--color--white-35)",
        "text-transform": "uppercase"
      }
    },
    ".featured_card-nav": {
      "main": {
        "display": "flex",
        "grid-row-gap": "var(--space-12)",
        "grid-column-gap": "var(--space-12)"
      }
    },
    ".featured_arrow": {
      "main": {
        "width": "calc(var(--space-40) - var(--space-2))",
        "height": "calc(var(--space-40) - var(--space-2))",
        "border-top-left-radius": "50%",
        "border-top-right-radius": "50%",
        "border-bottom-right-radius": "50%",
        "border-bottom-left-radius": "50%",
        "border-top-style": "solid",
        "border-top-color": "var(--color--white-18)",
        "border-right-style": "solid",
        "border-right-color": "var(--color--white-18)",
        "border-bottom-style": "solid",
        "border-bottom-color": "var(--color--white-18)",
        "border-left-style": "solid",
        "border-left-color": "var(--color--white-18)",
        "background-color": "transparent",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "cursor": "pointer",
        "transition": "background 0.25s ease, border-color 0.25s ease, transform 0.2s ease",
        "padding-top": "0",
        "padding-right": "0",
        "padding-bottom": "0",
        "padding-left": "0"
      }
    },
    ".featured_arrow:hover": {
      "main": {
        "background-color": "var(--color--white-10)",
        "border-top-color": "var(--color--white-40)",
        "border-right-color": "var(--color--white-40)",
        "border-bottom-color": "var(--color--white-40)",
        "border-left-color": "var(--color--white-40)",
        "transform": "scale(1.06)"
      }
    }
  }
}