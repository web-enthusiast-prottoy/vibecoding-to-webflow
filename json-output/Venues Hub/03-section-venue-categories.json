        "flex-direction": "column",
        "grid-row-gap": "var(--space-24)",
        "grid-column-gap": "var(--space-24)"
      }
    },
    ".venue-categories_row-top": {
      "main": {
        "display": "grid",
        "grid-row-gap": "var(--space-24)",
        "grid-column-gap": "var(--space-24)",
        "grid-template-columns": "1.5fr 1fr",
        "grid-template-rows": "auto"
      },
      "medium": {
        "grid-template-columns": "1fr 1fr",
        "grid-template-rows": "auto"
      },
      "small": {
        "grid-template-columns": "1fr",
        "grid-template-rows": "auto"
      }
    },
    ".venue-categories_row-bottom": {
      "main": {
        "display": "grid",
        "grid-row-gap": "var(--space-24)",
        "grid-column-gap": "var(--space-24)",
        "grid-template-columns": "1fr 1fr 1fr",
        "grid-template-rows": "auto"
      },
      "medium": {
        "grid-template-columns": "1fr 1fr",
        "grid-template-rows": "auto"
      },
      "small": {
        "grid-template-columns": "1fr",
        "grid-template-rows": "auto"
      }
    },
    ".venue-category_card": {
      "main": {
        "position": "relative",
        "border-top-left-radius": "var(--radius--large)",
        "border-top-right-radius": "var(--radius--large)",
        "border-bottom-right-radius": "var(--radius--large)",
        "border-bottom-left-radius": "var(--radius--large)",
        "overflow": "hidden",
        "display": "flex",
        "flex-direction": "column",
        "text-decoration": "none",
        "background-color": "var(--color--surface-4)",
        "transition": "transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1)"
      }
    },
    ".venue-category_card.is-large": {
      "main": {
        "aspect-ratio": "16 / 11"
      },
      "small": {
        "aspect-ratio": "3 / 2"
      },
      "tiny": {
        "aspect-ratio": "1 / 1"
      }
    },
    ".venue-category_card.is-medium": {
      "main": {
        "height": "100%"
      },
      "small": {
        "aspect-ratio": "3 / 2"
      },
      "tiny": {
        "aspect-ratio": "1 / 1"
      }
    },
    ".venue-category_card.is-small": {
      "main": {
        "aspect-ratio": "4 / 3"
      },
      "small": {
        "aspect-ratio": "3 / 2"
      },
      "tiny": {
        "aspect-ratio": "1 / 1"
      }
    },
    ".venue-category_image-wrap": {
      "main": {
        "width": "100%",
        "height": "100%",
        "position": "relative"
      }
    },
    ".venue-category_img": {
      "main": {
        "width": "100%",
        "height": "100%",
        "object-fit": "cover",
        "transition": "transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1)"
      }
    },
    ".venue-category_overlay": {
      "main": {
        "position": "absolute",
        "inset": "0",
        "background-image": "linear-gradient( to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.4) 40%, transparent 100% )",
        "z-index": "1"
      }
    },
    ".venue-category_content": {
      "main": {
        "position": "absolute",
        "bottom": "0",
        "left": "0",
        "width": "100%",
        "padding-top": "var(--space-32)",
        "padding-right": "var(--space-32)",
        "padding-bottom": "var(--space-32)",
