  "globalStyles": {
    ".footer_component": {
      "main": {
        "background-color": "var(--color--deep-black)",
        "padding-top": "var(--space-80)",
        "padding-bottom": "var(--space-48)",
        "position": "relative"
      }
    },
    ".footer_top": {
      "main": {
        "display": "flex",
        "justify-content": "center",
        "padding-bottom": "var(--space-80)",
        "position": "relative"
      }
    },
    ".footer_logo_img": {
      "main": {
        "height": "2.2rem",
        "width": "auto",
        "object-fit": "contain",
        "filter": "brightness(0) saturate(100%) invert(81%) sepia(21%) saturate(543%) hue-rotate(3deg) brightness(93%) contrast(89%)"
      }
    },
    ".footer_middle": {
      "main": {
        "padding-top": "var(--space-64)",
        "padding-bottom": "var(--space-64)"
      }
    },
    ".footer_grid": {
      "main": {
        "display": "grid",
        "grid-template-columns": "1fr 1fr 1fr 1fr",
        "grid-row-gap": "var(--space-32)",
        "grid-column-gap": "var(--space-32)",
        "grid-template-rows": "auto"
      },
      "medium": {
        "grid-template-columns": "1fr 1fr",
        "grid-row-gap": "var(--space-48)",
        "grid-column-gap": "var(--space-48)",
        "grid-template-rows": "auto"
      },
      "tiny": {
        "grid-template-columns": "1fr",
        "grid-template-rows": "auto"
      }
    },
    ".footer_column": {
      "main": {
        "display": "flex",
        "flex-direction": "column",
        "grid-row-gap": "var(--space-24)",
        "grid-column-gap": "var(--space-24)"
      }
    },
    ".footer_heading": {
      "main": {
        "font-size": "var(--text--title-sm)",
        "color": "var(--color--gold)",
        "margin-bottom": "var(--space-4)",
        "font-family": "var(--font--heading)",
        "font-weight": "var(--weight--medium)"
      }
    },
    ".footer_links": {
      "main": {
        "display": "flex",
        "flex-direction": "column",
        "grid-row-gap": "var(--space-18)",
        "grid-column-gap": "var(--space-18)"
      }
    },
    ".footer_link": {
      "main": {
        "font-size": "var(--text--link-small)",
        "color": "var(--color--light-paragraph)",
        "transition": "color 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
        "font-weight": "var(--weight--light)"
      }
    },
    ".footer_link:hover": {
      "main": {
