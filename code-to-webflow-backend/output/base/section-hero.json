        "display": "block",
        "font-size": "var(--font-size-h1)",
        "letter-spacing": "-0.02em",
        "white-space": "nowrap"
      },
      "small": {
        "font-size": "var(--font-size-h2)",
        "white-space": "normal"
      },
      "tiny": {
        "font-size": "var(--font-size-h4)",
        "white-space": "normal"
      }
    },
    ".hero_heading-box": {
      "main": {
        "display": "inline-flex",
        "align-items": "center",
        "justify-content": "center",
        "background-image": "linear-gradient(135deg, #ffffff, var(--color-accent))",
        "color": "var(--bg-primary)",
        "border-top-style": "none",
        "border-right-style": "none",
        "border-bottom-style": "none",
        "border-left-style": "none",
        "border-top-left-radius": "var(--radius-small)",
        "border-top-right-radius": "var(--radius-small)",
        "border-bottom-right-radius": "var(--radius-small)",
        "border-bottom-left-radius": "var(--radius-small)",
        "padding-top": "0.25em",
        "padding-right": "0.3em",
        "padding-bottom": "0.15em",
        "padding-left": "0.3em",
        "line-height": "0.8",
        "margin-left": "var(--space-2)",
        "vertical-align": "middle"
      },
      "small": {
        "display": "inline-block"
      },
      "tiny": {
        "border-top-width": "2px",
        "border-right-width": "2px",
        "border-bottom-width": "2px",
        "border-left-width": "2px",
        "padding-top": "0",
        "padding-right": "8px",
        "padding-bottom": "4px",
        "padding-left": "8px",
        "display": "inline-block"
      }
    },
    ".hero_subtext": {
      "main": {
        "margin-top": "var(--space-7)",
        "font-size": "var(--text-size-medium)",
        "color": "var(--color-text-secondary)",
        "line-height": "1.7",
        "max-width": "72ch",
        "width": "100%",
        "margin-left": "auto",
        "margin-right": "auto",
        "text-wrap": "balance"
      }
    },
    ".hero_video-wrapper": {
      "main": {
        "margin-top": "var(--space-14)",
        "width": "100%",
        "max-width": "55rem",
        "position": "relative"
      }
    },
    ".hero_video-card": {
      "main": {
        "position": "relative",
        "aspect-ratio": "2 / 1",
        "overflow": "hidden",
        "border-top-left-radius": "var(--radius-medium)",
        "border-top-right-radius": "var(--radius-medium)",
        "border-bottom-right-radius": "var(--radius-medium)",
        "border-bottom-left-radius": "var(--radius-medium)",
        "cursor": "pointer"
      }
    },
    ".hero_video-img": {
      "main": {
        "width": "100%",
        "height": "100%",
        "object-fit": "cover",
        "filter": "brightness(0.65) contrast(1.05)",
        "transition": "transform 0.6s cubic-bezier(0, 0, 0.2, 1), filter 0.45s cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
    ".hero_video-card:hover .hero_video-img": {
      "main": {
        "transform": "scale(1.04)",
        "filter": "brightness(0.72) contrast(1.05)"
      }
    },
    ".hero_play-btn": {
      "main": {
        "position": "absolute",
        "top": "50%",
        "left": "50%",
        "transform": "translate(-50%, -50%)",
        "width": "72px",
        "height": "72px",
        "border-top-left-radius": "50%",
        "border-top-right-radius": "50%",
        "border-bottom-right-radius": "50%",
        "border-bottom-left-radius": "50%",
        "background-color": "rgba(255, 255, 255, 0.12)",
        "border-top-width": "1px",
        "border-right-width": "1px",
        "border-bottom-width": "1px",
        "border-left-width": "1px",
        "border-top-style": "solid",
        "border-right-style": "solid",
        "border-bottom-style": "solid",
        "border-left-style": "solid",
        "border-top-color": "rgba(255, 255, 255, 0.3)",
        "border-right-color": "rgba(255, 255, 255, 0.3)",
        "border-bottom-color": "rgba(255, 255, 255, 0.3)",
        "border-left-color": "rgba(255, 255, 255, 0.3)",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "transition": "transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
    ".hero_play-btn:hover": {
      "main": {
        "background-color": "var(--color-accent)",
        "border-top-color": "var(--color-accent)",
        "border-right-color": "var(--color-accent)",
        "border-bottom-color": "var(--color-accent)",
        "border-left-color": "var(--color-accent)",
        "transform": "translate(-50%, -50%) scale(1.1)"
      }
    },
    ".hero_play-btn:hover .hero_play-btn-icon": {
      "main": {
        "fill": "var(--bg-primary)"
      }
    },
    ".hero_cta-wrap": {
      "main": {
        "margin-top": "var(--space-11)"
      }
    },
    ".hero_cta-btn": {
      "main": {
        "font-size": "0.8125rem"
      }
