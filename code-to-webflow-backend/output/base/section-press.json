  "globalStyles": {
    ".section_press": {
      "main": {
        "position": "relative",
        "padding-top": "var(--space-8)",
        "padding-right": "0",
        "padding-bottom": "var(--space-8)",
        "padding-left": "0",
        "border-bottom": "1px solid var(--color-border)",
        "background-color": "var(--bg-primary)"
      }
    },
    ".press_fade-left": {
      "main": {
        "position": "absolute",
        "top": "0",
        "bottom": "0",
        "width": "120px",
        "z-index": "2",
        "pointer-events": "none",
        "left": "0",
        "background-image": "linear-gradient(to right, var(--bg-primary), transparent)"
      }
    },
    ".press_fade-right": {
      "main": {
        "position": "absolute",
        "top": "0",
        "bottom": "0",
        "width": "120px",
        "z-index": "2",
        "pointer-events": "none",
        "right": "0",
        "background-image": "linear-gradient(to left, var(--bg-primary), transparent)"
      }
    },
    ".press_logo": {
      "main": {
        "height": "38px",
        "width": "auto",
        "opacity": "0.5",
        "filter": "grayscale(100%)",
        "display": "block",
        "transition": "opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
    ".press_logo:hover": {
      "main": {
        "opacity": "1"
      }
    }
  }
