{
  "_mime": "section",
  "__meta": {
    "version": 2,
    "normalized": true,
    "complexSelectorsResolved": true
  },
  "name": "cta-section",
  "nodes": [
    {
      "type": "Block",
      "tag": "section",
      "classes": [
        "cta-section"
      ],
      "id": "contact",
      "children": [
        {
          "type": "Block",
          "tag": "div",
          "classes": [
            "padding-global"
          ],
          "children": [
            {
              "type": "Block",
              "tag": "div",
              "classes": [
                "container-large"
              ],
              "children": [
                {
                  "type": "Block",
                  "tag": "div",
                  "classes": [
                    "cta-section_component"
                  ],
                  "children": [
                    {
                      "type": "Heading",
                      "tag": "h2",
                      "classes": [
                        "cta-section_title"
                      ],
                      "text": "Ready to",
                      "children": [
                        {
                          "type": "Block",
                          "tag": "span",
                          "classes": [
                            "cta-section_accent"
                          ],
                          "text": "scale?",
                          "children": []
                        }
                      ]
                    },
                    {
                      "type": "Paragraph",
                      "classes": [
                        "cta-section_body"
                      ],
                      "text": "We only take on four new partners per quarter to ensure architectural excellence. Book your discovery session to see if we're the right fit.",
                      "children": []
                    },
                    {
                      "type": "Link",
                      "classes": [
                        "button",
                        "cta-section_btn"
                      ],
                      "id": "ctaBtn",
                      "attributes": {
                        "href": "mailto:hello@modadigital.com"
                      },
                      "text": "Book Your Discovery Call",
                      "children": []
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "globalStyles": {
    ".cta-section": {
      "main": {
        "position": "relative",
        "padding-top": "calc(var(--padding-section-large)",
        "padding-right": "*",
        "padding-bottom": "1.5)",
        "padding-left": "0",
        "background-color": "var(--bg-primary)",
        "border-top": "1px solid var(--color-border)",
        "text-align": "center",
        "overflow": "hidden",
        "z-index": "1"
      },
      "small": {
        "padding-top": "var(--padding-section-medium)",
        "padding-right": "0",
        "padding-bottom": "0",
        "padding-left": "0"
      }
    },
    ".cta-section_component": {
      "main": {
        "position": "relative",
        "max-width": "80rem",
        "margin-top": "0",
        "margin-right": "auto",
        "margin-bottom": "0",
        "margin-left": "auto"
      }
    },
    ".cta-section_title": {
      "main": {
        "font-family": "var(--font-condensed)",
        "font-weight": "900",
        "font-size": "clamp(1.5rem, 5vw + 1rem, 4.5rem)",
        "text-transform": "uppercase",
        "line-height": "1.1",
        "letter-spacing": "-0.02em",
        "margin-bottom": "var(--space-6)",
        "color": "var(--color-text-primary)",
        "text-align": "center",
        "white-space": "nowrap"
      },
      "small": {
        "font-size": "var(--font-size-h3)",
        "white-space": "normal"
      }
    },
    ".cta-section_accent": {
      "main": {
        "color": "var(--color-accent)"
      }
    },
    ".cta-section_body": {
      "main": {
        "font-size": "var(--text-size-medium)",
        "color": "var(--color-text-secondary)",
        "line-height": "1.6",
        "margin-bottom": "var(--space-12)",
        "max-width": "55ch",
        "margin-inline": "auto"
      }
    },
    ".cta-section_btn": {
      "main": {
        "font-size": "0.8125rem"
      }
    }
  }
}