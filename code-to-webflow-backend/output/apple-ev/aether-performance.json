  "globalStyles": {
    ".aether-performance": {
      "main": {
        "background-color": "var(--aether-black,#000)",
        "position": "relative",
        "overflow": "hidden",
        "color": "#fff"
      }
    },
    ".aether-perf-bg": {
      "main": {
        "pointer-events": "none",
        "position": "absolute",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0",
        "overflow": "hidden"
      }
    },
    ".aether-speed-lines": {
      "main": {
        "opacity": ".07",
        "flex-direction": "column",
        "justify-content": "center",
        "gap": "40px",
        "display": "flex",
        "position": "absolute",
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      }
    },
    ".aether-speed-line": {
      "main": {
        "transform-origin": "0",
        "background-image": "linear-gradient(90deg,rgba(0, 0, 0, 0),#fff,rgba(0, 0, 0, 0))",
        "width": "100%",
        "height": "1px",
        "animation": "2.5s ease-in-out infinite speedLine"
      }
    },
    ".aether-perf-component": {
      "main": {
        "z-index": "1",
        "position": "relative"
      }
    },
    ".aether-perf-title-line": {
      "main": {
        "will-change": "transform,opacity",
        "display": "block"
      }
    },
    ".aether-stats-grid": {
      "main": {
        "grid-template-columns": "repeat(4,1fr)",
        "gap": "40px",
        "margin-top": "64px",
        "display": "grid"
      },
      "medium": {
        "gap": "24px",
        "grid-template-columns": "repeat(2,1fr)"
      },
      "small": {
        "grid-template-columns": "repeat(2,1fr)"
      },
      "tiny": {
        "grid-template-columns": "repeat(2,1fr)",
        "gap": "16px"
      }
    },
    ".aether-stat": {
      "main": {
        "will-change": "transform,opacity",
        "border-top": "1px solid rgba(255, 255, 255, 0.102)",
        "flex-direction": "column",
        "gap": "8px",
        "padding-top": "40px",
        "padding-right": "0",
        "padding-bottom": "40px",
        "padding-left": "0",
        "display": "flex"
      },
      "medium": {
        "padding-top": "24px",
        "padding-right": "0",
        "padding-bottom": "24px",
        "padding-left": "0"
      }
    },
    ".aether-stat-number": {
      "main": {
        "color": "#fff",
        "letter-spacing": "-.02em",
        "font-variant-numeric": "tabular-nums",
        "min-width": "4ch",
        "font-size": "clamp(40px,5vw,72px)",
        "font-weight": "300",
        "line-height": "1"
      },
      "tiny": {
        "font-size": "40px"
      }
    },
    ".aether-stat-label": {
      "main": {
        "color": "rgba(255, 255, 255, 0.749)",
        "letter-spacing": ".04em",
        "text-transform": "uppercase",
        "font-size": "13px"
      }
    },
    ".display-block": {
      "main": {
        "display": "block"
      }
    }
  }
