        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0",
        "z-index": "0",
        "pointer-events": "none",
        "transition": "background-color 1s ease,opacity 1s ease"
      }
    },
    ".config-ui-overlay": {
      "main": {
        "position": "absolute",
