        "<style>",
        "@keyframes scrollHint{0%{transform-origin:top;opacity:0;transform:scaleY(0)}50%{transform-origin:top;opacity:1;transform:scaleY(1)}to{transform-origin:bottom;opacity:0;transform:scaleY(0)}}",
        "@keyframes speedLine{0%{opacity:0;transform:scaleX(0)translate(-100%)}10%{opacity:1}80%{opacity:1;transform:scaleX(1)translate(0)}to{opacity:0;transform:scaleX(1)translate(100%)}}",
        "@keyframes fadeUp{0%{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}",
        "@keyframes spin{0%{transform:rotate(0)}to{transform:rotate(360deg)}}",
        "@keyframes pulse{50%{opacity:.5}}",
        "@keyframes appleShimmer{0%{opacity:.1}50%{opacity:.25}to{opacity:.1}}",
        "@keyframes appleWarnFade{0%{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}",
        "",
        "@keyframes appleProgressStroke {",
