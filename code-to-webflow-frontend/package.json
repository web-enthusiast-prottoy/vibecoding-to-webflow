{
  "name": "code-to-webflow-frontend",
  "version": "1.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "npm install && tsc -p tsconfig.json && webflow extension bundle",
    "dev": "npm install && concurrently -r \"webflow extension serve\" \"tsc -p tsconfig.json --watch --preserveWatchOutput\"",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@webflow/designer-extension-typings": "^2.0.29",
    "@webflow/webflow-cli": "^1.21.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.5.7",
    "eslint-plugin-promise": "^6.1.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@webflow/data-types": "^1.3.0"
  }
}
